#!/usr/bin/env python3
"""A fake Bitwarden CLI for tests — emulates just the `bw` surface the daemon uses,
backed by a JSON vault at $FAKE_BW_VAULT. No network, no real Bitwarden.

Supported:
  bw unlock --passwordenv BW_PASSWORD --raw   -> prints a session if BW_PASSWORD is correct
  bw sync                                      -> no-op success
  bw list items [--search Q]                   -> JSON array (filtered by name/username/uri)
  bw get item <id|name|uri>                    -> the one matching item (with login.password),
                                                  or errors 'Not found.' / 'More than one result found.'
"""
import json, os, sys

ACCEPT_PW = "correct-pw"


def vault():
    with open(os.environ["FAKE_BW_VAULT"]) as f:
        return json.load(f)


def hay(i):
    login = i.get("login") or {}
    parts = [i.get("name", "") or "", login.get("username") or ""] + \
            [u.get("uri", "") or "" for u in login.get("uris", [])]
    return " ".join(parts).lower()


def main():
    a = sys.argv[1:]
    if not a:
        sys.exit(1)
    cmd = a[0]

    if cmd == "unlock":
        if os.environ.get("BW_PASSWORD") == ACCEPT_PW:
            sys.stdout.write("FAKE-SESSION-KEY")
            return
        sys.stderr.write("Invalid master password.")
        sys.exit(1)

    if cmd == "sync":
        return

    if cmd == "list" and len(a) >= 2 and a[1] == "items":
        items = vault()
        if "--search" in a:
            q = a[a.index("--search") + 1].lower()
            items = [i for i in items if q in hay(i)]
        sys.stdout.write(json.dumps(items))
        return

    if cmd == "get" and len(a) >= 3 and a[1] == "item":
        ref = a[2]
        items = vault()
        for i in items:                       # exact id wins
            if i.get("id") == ref:
                sys.stdout.write(json.dumps(i))
                return
        rl = ref.lower()
        cands = [i for i in items if rl in hay(i)]
        if len(cands) == 1:
            sys.stdout.write(json.dumps(cands[0]))
            return
        if len(cands) > 1:
            sys.stderr.write("More than one result found.")
            sys.exit(1)
        sys.stderr.write("Not found.")
        sys.exit(1)

    sys.stderr.write("fake-bw: unhandled args: " + " ".join(a))
    sys.exit(2)


if __name__ == "__main__":
    main()
